# Domain for TLS certificate (auto-obtains from Let's Encrypt)
DOMAIN=syncode.example.com

# Email for Let's Encrypt ACME registration
ACME_EMAIL=admin@example.com

# Origin server public IP
ORIGIN_HOST=203.0.113.10

# Origin ports (nginx inside Docker on the origin server)
ORIGIN_PORT_PROD=4443
ORIGIN_PORT_STAGING=4444
