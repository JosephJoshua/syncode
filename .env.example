# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/syncode

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=syncode

# E2B
E2B_API_KEY=

# Stub configuration for the controlplane
# Set to true to use simulated clients instead of real services
USE_EXECUTION_STUB=false
USE_AI_STUB=false
USE_COLLAB_STUB=false

# Collab plane
COLLAB_PLANE_URL=http://localhost:3001

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# SonarCloud
SONAR_TOKEN=

# General
NODE_ENV=development
