# Merged union of all service env vars used for local development.
# For production, each service reads its own apps/<name>/.env first.

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/syncode

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars
COLLAB_JWT_SECRET=change-me-in-production-min-32-chars

# Shared secret for internal plane-to-plane HTTP callbacks (collab -> control).
# Both control-plane and collab-plane must agree on this value.
INTERNAL_CALLBACK_SECRET=change-me-in-production-min-32-chars

# LiveKit (defaults match docker-compose.yml)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_CLIENT_URL=ws://localhost:7880  # browser-facing URL (set when LIVEKIT_URL is Docker-internal)

# S3-compatible storage (SeaweedFS S3 gateway on port 8333)
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=syncode
S3_SECRET_KEY=syncode-secret
S3_BUCKET=syncode
# S3_PUBLIC_ENDPOINT — browser-facing URL for presigned URLs (defaults to S3_ENDPOINT)
# Local Vite dev proxies /storage to SeaweedFS; in prod, set this to https://<domain>/storage
S3_PUBLIC_ENDPOINT=http://localhost:5173/storage

# E2B (code execution sandbox)
E2B_API_KEY=

# AI platform (ai-plane)
AI_PROVIDER=openai-compatible
AI_PLATFORM_BASE_URL=https://lab.cs.tsinghua.edu.cn/ai-platform/api/v1
AI_PLATFORM_API_KEY=
AI_PLATFORM_MODEL=qwen3.5-mini
AI_REQUEST_TIMEOUT_MS=60000

# Stub configuration for the control-plane
# Set to true to use simulated clients instead of real services
USE_EXECUTION_STUB=false
USE_AI_STUB=false
USE_COLLAB_STUB=false

# Platform planes
COLLAB_PLANE_URL=http://localhost:3001
# COLLAB_PLANE_CLIENT_URL=ws://localhost:3001  # browser-facing URL (set when COLLAB_PLANE_URL is Docker-internal)
CONTROL_PLANE_URL=http://localhost:3000

# Trusted reverse proxies for control-plane client IP resolution (comma-separated)
# Leave empty for local direct access. Production compose requires the exact nginx/proxy CIDR.
TRUSTED_PROXIES=

# AI plane (LLM proxy)
AI_PROVIDER=openai-compatible
AI_PLATFORM_BASE_URL=https://lab.cs.tsinghua.edu.cn/ai-platform/api/v1
AI_PLATFORM_API_KEY=
AI_PLATFORM_MODEL=qwen3.5-mini
AI_HINT_MODEL=qwen3.5-mini
AI_REQUEST_TIMEOUT_MS=60000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_ADMIN_PASSWORD=changeme

# SonarCloud
SONAR_TOKEN=

# General
NODE_ENV=development

# PRODUCTION ONLY:
# Uncomment and fill these when deploying to a server.
#
# DOMAIN=syncode.anggita.org            # Base domain (shared by prod and staging)
# NGINX_PORT=4443                       # Staging auto-overrides to 4444 via --staging flag
# GRAFANA_PORT=3334                     # Staging auto-overrides to 3335 via --staging flag
# GRAFANA_SUBDOMAIN=grafana             # Staging auto-overrides to "grafana.staging" via --staging flag
# REGISTRY_PREFIX=ghcr.io/josephjoshua  # Container registry (e.g. ghcr.nju.edu.cn/josephjoshua)
# IMAGE_TAG=latest                      # Staging auto-overrides to "develop" via --staging flag
#
# Postgres (used by the postgres container; app uses DATABASE_URL)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=syncode
#
# Redis (prod requires a password in the URL)
# REDIS_PASSWORD=changeme
# REDIS_URL=redis://:changeme@redis:6379
