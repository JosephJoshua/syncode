{
  "name": "@syncode/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/write-cjs-package-json.js",
    "typecheck": "tsc --noEmit",
    "generate": "./load-env.sh drizzle-kit generate",
    "migrate": "./load-env.sh node --import tsx src/migrate.ts",
    "push": "./load-env.sh drizzle-kit push",
    "seed": "./load-env.sh node --import tsx src/seed.ts",
    "studio": "./load-env.sh drizzle-kit studio",
    "lint": "biome check ."
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@syncode/tsconfig": "workspace:^",
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
