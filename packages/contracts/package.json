{
  "name": "@syncode/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./stubs": {
      "types": "./src/stubs.ts",
      "default": "./dist/stubs.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@syncode/shared": "workspace:^",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@syncode/tsconfig": "workspace:^",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
