{
  "name": "@syncode/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.writeFileSync('dist/package.json',JSON.stringify({type:'commonjs'}))\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@syncode/shared": "workspace:^",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@syncode/tsconfig": "workspace:^",
    "@types/node": "^25.3.3",
    "typescript": "5.9.2"
  }
}
