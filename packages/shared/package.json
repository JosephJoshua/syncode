{
  "name": "@syncode/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "typesVersions": {
    "*": {
      "ports": [
        "./src/ports/index.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./ports": {
      "types": "./src/ports/index.ts",
      "default": "./dist/ports/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@syncode/tsconfig": "workspace:^",
    "@types/node": "^25.3.3",
    "typescript": "5.9.2",
    "vitest": "^3.0.0"
  }
}
