# Control plane API base URL (proxied through Nginx in production)
VITE_API_URL=http://localhost:3000

# Use mock sessions in the dashboard for development and testing
VITE_DASHBOARD_USE_MOCK_SESSIONS=false

# Use mocked tag data for the Problems page filter sidebar
VITE_PROBLEMS_FILTER_TAGS_USE_MOCK_SESSIONS=true

# Use mocked card data for the Problems page problem list endpoint
VITE_PROBLEMS_CARDS_USE_MOCK_SESSIONS=true

VITE_USE_PROBLEM_DETAIL_MOCK=true
