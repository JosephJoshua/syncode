# Redis
REDIS_URL=redis://localhost:6379

# AI platform
AI_PLATFORM_BASE_URL=https://llmapi.paratera.com
AI_PLATFORM_API_KEY=replace-me
AI_PLATFORM_MODEL=DeepSeek-V3.2-Instruct
AI_STT_MODEL=GLM-ASR-2512
# Optional: leave unset if your proxy plan does not include /v1/audio/speech models
# AI_TTS_MODEL=
# AI_TTS_VOICE=Chelsie
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_CONCURRENT_TASKS=20
AI_RESERVED_REALTIME_SLOTS=10
AI_MAX_BATCH_CONCURRENT_TASKS=10

# S3 / SeaweedFS
S3_ENDPOINT=http://localhost:8333
S3_PUBLIC_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=syncode
S3_SECRET_KEY=syncode-secret
S3_BUCKET=syncode
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# General
NODE_ENV=development
