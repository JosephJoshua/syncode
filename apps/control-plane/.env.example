# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/syncode

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Collab-plane token (separate from auth to prevent token confusion)
COLLAB_JWT_SECRET=change-me-in-production-min-32-chars

# S3-compatible storage (SeaweedFS S3 gateway on port 8333)
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=syncode
S3_SECRET_KEY=syncode-secret
S3_BUCKET=syncode
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880

# Plane URLs
COLLAB_PLANE_URL=http://localhost:3001

# Stub flags (set to true to skip real plane services in local dev)
USE_EXECUTION_STUB=false
USE_AI_STUB=false
USE_COLLAB_STUB=false

# Rate limiting
THROTTLE_TTL_SECS=60
THROTTLE_LIMIT=10

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# General
NODE_ENV=development
PORT=3000
